SPRING_PROFILES_ACTIVE=prod

# Database container
DB_NAME=afrochowdb
DB_USERNAME=afrochow
DB_PASSWORD=change-me
MYSQL_ROOT_PASSWORD=change-me-root

# App/security
APP_NAME=Afrochow
APP_URL=https://api.afrochow.ca
APP_FRONTEND_URL=https://www.afrochow.ca
APP_BASE_URL=https://api.afrochow.ca
APP_JWT_SECRET=change-me
APP_JWT_EXPIRATION=900000
APP_JWT_REFRESH_EXPIRATION=604800000
APP_JWT_ENCRYPTION_KEY=change-me-32-byte-base64-or-secret
APP_TOKEN_SECRET=change-me
APP_UPLOAD_MAX_FILE_SIZE=10485760
CORS_ALLOWED_ORIGINS=https://afrochow.ca,https://www.afrochow.ca
COOKIE_DOMAIN=.afrochow.ca

# Mail
SPRING_MAIL_ENABLED=true
RESEND_API_KEY=change-me
RESEND_FROM=noreply@afrochow.ca

# Cloudinary
CLOUDINARY_CLOUD_NAME=change-me
CLOUDINARY_API_KEY=change-me
CLOUDINARY_API_SECRET=change-me

# Stripe
STRIPE_SECRET_KEY=change-me
STRIPE_WEBHOOK_SECRET=change-me
STRIPE_PLATFORM_FEE_PERCENT=10
STRIPE_CONNECT_REQUIRED=true

# Google OAuth
GOOGLE_CLIENT_ID=change-me
GOOGLE_CLIENT_SECRET=change-me
GOOGLE_REDIRECT_URI=postmessage

# Kafka inside Docker network
KAFKA_BOOTSTRAP_SERVERS=kafka:19092
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_TOPIC_DOMAIN_EVENTS=afrochow.domain-events
KAFKA_TOPIC_DOMAIN_EVENTS_RETRY=afrochow.domain-events.retry
KAFKA_TOPIC_DOMAIN_EVENTS_DLQ=afrochow.domain-events.dlq
KAFKA_CONSUMER_RETRY_BACKOFF_MS=1000
KAFKA_CONSUMER_MAX_RETRY_ATTEMPTS=3
KAFKA_NOTIFICATIONS_CONSUMER_ENABLED=true
KAFKA_PAYMENT_TRANSFER_CONSUMER_ENABLED=true
KAFKA_ADDRESS_GEOCODING_CONSUMER_ENABLED=true

# Redis inside Docker network
REDIS_PASSWORD=change-me-redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_HOST_PORT=6379
REDIS_MAXMEMORY=512mb

# CPX32 runtime tuning
JAVA_OPTS=-Xms512m -Xmx1536m
APP_MEMORY_LIMIT=2g
DB_POOL_MAX_SIZE=10
DB_POOL_MIN_IDLE=2
MYSQL_MEMORY_LIMIT=2g
MYSQL_INNODB_BUFFER_POOL_SIZE=1G
MYSQL_MAX_CONNECTIONS=100
MYSQL_HOST_PORT=3306
KAFKA_MEMORY_LIMIT=1536m
KAFKA_HEAP_OPTS=-Xms768m -Xmx1g
REDIS_MEMORY_LIMIT=768m

# ------------------------
# DATABASE BACKUPS TO S3
# ------------------------
AWS_REGION=ca-central-1
AWS_ACCESS_KEY_ID=change-me-access-key
AWS_SECRET_ACCESS_KEY=change-me-secret-key
AWS_S3_BACKUP_BUCKET=change-me-afrochow-db-backups
DB_BACKUP_CRON=0 2 * * *
DB_BACKUP_TIMEZONE=America/Edmonton
DB_BACKUP_S3_PREFIX=mysql
DB_BACKUP_LOCAL_RETENTION_DAYS=7
DB_BACKUP_ONESHOT=false
DB_BACKUP_RUN_ON_STARTUP=false
NGINX_MEMORY_LIMIT=256m

# Operational switches
SEED_ON_STARTUP=false
